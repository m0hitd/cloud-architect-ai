# ============================================================
# Cloud Architect AI — Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in your real values.
#   cp .env.example .env.local
#
# NEVER commit .env.local to version control.
# All variables prefixed with VITE_ are exposed to the browser.
# ============================================================


# ------------------------------------------------------------
# [REQUIRED] Google Gemini API Key
# ------------------------------------------------------------
# The app uses the Gemini API directly (via @google/generative-ai SDK).
# The model currently used is: gemini-2.5-flash
#
# How to get your key:
#   1. Go to https://aistudio.google.com/app/apikey
#   2. Click "Create API key"
#   3. Copy the key and paste it below
#
# Note: Keep this key private. Never share it publicly.
VITE_GEMINI_API_KEY=your_gemini_api_key_here


# ------------------------------------------------------------
# [OPTIONAL] Firebase Hosting Configuration
# ------------------------------------------------------------
# Only required if you want to deploy the app to Firebase Hosting.
# These values come from your Firebase project settings.
#
# How to get these values:
#   1. Go to https://console.firebase.google.com/
#   2. Select your project (or create one)
#   3. Click the gear icon > Project settings
#   4. Under "Your apps" > Web app, click "Config"
#   5. Copy the values from the firebaseConfig object
#
# The app works fully without Firebase — it is only used for hosting.
# VITE_FIREBASE_API_KEY=your_firebase_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your_project_id
# VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
# VITE_FIREBASE_APP_ID=your_firebase_app_id
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX  # optional, only if Analytics is enabled
